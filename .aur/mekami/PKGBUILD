# Maintainer: Wolf258 <wolf258@users.noreply.github.com>
# PKGBUILD for the mekami package on the AUR.
#
# Builds the mekami CLI from source on the user's machine. Requires
# Go >= 1.26 at build time (the go package in [extra] is currently
# well past that, but the requirement is documented for future-proofing).
# If the user wants a prebuilt binary, they should install `mekami-bin`
# instead.
#
# The binary lives in a single module: mekami-cli (with the former
# mekami-core tree fused in as internal/core). We pin a single tag
# in the upstream umbrella repo and run the project's build.sh,
# which already handles the dev all_gen rewrite + ldflags.
#
# To bump pkgver: tag the umbrella repo with `v<version>` and push
# the tag.

pkgname=mekami
pkgver=0.1.0
pkgrel=1
pkgdesc="SQLite-backed code graph for LLM agents, exposed over the Model Context Protocol"
arch=('x86_64' 'aarch64')
url="https://github.com/Wolf258/Mekami"
license=('MIT')
depends=('glibc')
makedepends=('go>=1.26' 'git')
source=("git+https://github.com/Wolf258/Mekami.git#tag=v${pkgver}")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/Mekami"
	# Echo the literal pkgver: the umbrella tag is the canonical
	# version. We override pkgver() only because git sources honor
	# the function for tag-derived versions; we want to pin the
	# package's own declared version instead.
	echo "${pkgver}"
}

prepare() {
	cd "$srcdir/Mekami"
	# build.sh regenerates all_gen.go with the dev builtin set
	# and produces the binary in the repo root. No further
	# preparation is needed: the umbrella repo is one module.
	return 0
}

build() {
	cd "$srcdir/Mekami"
	# build.sh runs the dev-allgen helper to populate all_gen.go
	# with the dev builtin set, then invokes go build with the
	# version ldflag. We just pass the package version.
	./build.sh "${pkgver}"
}

check() {
	cd "$srcdir/Mekami"
	# Run the unit tests from the repo root so the committed
	# go.work stays in scope.
	go test -short ./mekami-cli/...
}

package() {
	cd "$srcdir/Mekami"
	install -Dm755 mekami "$pkgdir/usr/bin/mekami"
	# LICENSE lives at the umbrella repo root.
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
